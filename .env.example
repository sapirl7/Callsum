<![CDATA[# Minimal local configuration for the polling bot
TELEGRAM_BOT_TOKEN=
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_URL=

# AWS / storage
AWS_REGION=us-east-1
S3_BUCKET_NAME=callsum-prod
DYNAMODB_TABLE_NAME=callsum-jobs
RATE_LIMITS_TABLE_NAME=callsum-jobs-rate-limits

# Callback path
# For local debugging you can leave this empty and fetch results via /status
CALLBACK_URL=
TELEGRAM_SECRET_TOKEN=
RUNPOD_CALLBACK_TOKEN=

# Optional: DigitalOcean Spaces instead of AWS S3
S3_ENDPOINT_URL=
DO_SPACES_SECRET_ARN=
]]>
