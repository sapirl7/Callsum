# Terraform Variables Example
# Скопируйте этот файл в terraform.tfvars и заполните значения

# === ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ ===

# Telegram Bot Token (получите у @BotFather)
telegram_bot_token = "YOUR_TELEGRAM_BOT_TOKEN"

# Telegram Secret Token (для защиты webhook)
# Сгенерируйте случайную строку (например: openssl rand -hex 32)
# Укажите этот же токен при установке webhook через Telegram API
telegram_secret_token = "YOUR_RANDOM_SECRET_TOKEN"

# Hugging Face Token (для Pyannote модели)
# Получите на https://huggingface.co/settings/tokens
hf_token = "YOUR_HF_TOKEN"

# RunPod API Key
# Получите на https://www.runpod.io/console/user/settings
runpod_api_key = "YOUR_RUNPOD_API_KEY"

# RunPod Endpoint URL (создается после деплоя RunPod сервиса)
# Формат: https://api.runpod.ai/v2/{endpoint_id}
runpod_endpoint_url = "https://api.runpod.ai/v2/YOUR_ENDPOINT_ID"

# === ОПЦИОНАЛЬНЫЕ ПАРАМЕТРЫ ===

# AWS Region
aws_region = "us-east-1"

# Environment (dev, staging, prod)
environment = "prod"

# S3 Bucket Name (должно быть уникальным глобально)
s3_bucket_name = "callsum-prod-your-unique-suffix"

# Email для алертов (оставьте пустым если не нужны email уведомления)
alert_email = "your@email.com"

# Бюджетные лимиты (USD)
monthly_budget_limit = 25  # Общий месячный лимит
runpod_monthly_limit = 15  # Лимит для RunPod

# Включить детальное отслеживание расходов
enable_cost_tracking = true

# Lambda конфигурация
lambda_timeout = 60      # секунд
lambda_memory  = 512     # MB

# DynamoDB таблица для jobs
dynamodb_table_name = "callsum-jobs"

# === DIGITALOCEAN SPACES (ОПЦИОНАЛЬНО) ===
# Используйте если хотите хранить файлы в DigitalOcean Spaces вместо AWS S3
# Стоимость: ~$5/месяц за 250GB (дешевле чем AWS S3)

# Включить DigitalOcean Spaces вместо AWS S3
use_digitalocean_spaces = false  # Установите true для использования DO Spaces

# DigitalOcean Spaces Endpoint
# Формат: https://<region>.digitaloceanspaces.com
# Регионы: nyc3, sfo3, sgp1, fra1, ams3
s3_endpoint = "https://fra1.digitaloceanspaces.com"

# DigitalOcean Spaces Keys
# Получите в панели: DigitalOcean -> API -> Spaces Keys
s3_access_key = "YOUR_DO_SPACES_ACCESS_KEY"
s3_secret_key = "YOUR_DO_SPACES_SECRET_KEY"

# ВАЖНО: При использовании DO Spaces создайте Space вручную с именем из s3_bucket_name
# Например: callsum-prod-your-unique-suffix

# === ИНСТРУКЦИЯ ПО НАСТРОЙКЕ DIGITALOCEAN SPACES ===
# 1. Создайте аккаунт на digitalocean.com
# 2. Перейдите: Manage -> Spaces -> Create Space
# 3. Выберите регион (например: Frankfurt - fra1)
# 4. Имя Space: такое же как s3_bucket_name выше
# 5. Перейдите: API -> Spaces Keys -> Generate New Key
# 6. Скопируйте Access Key и Secret Key в переменные выше
# 7. Установите use_digitalocean_spaces = true
# 8. Запустите terraform apply
