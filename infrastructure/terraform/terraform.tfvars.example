<![CDATA[# Terraform Variables Example
# Copy this file to terraform.tfvars and fill in the values

# === REQUIRED PARAMETERS ===

# Telegram Bot Token (get from @BotFather)
telegram_bot_token = "YOUR_TELEGRAM_BOT_TOKEN"

# Telegram Secret Token (for webhook protection)
# Generate a random string (e.g.: openssl rand -hex 32)
# Use the same token when setting the webhook via Telegram API
telegram_secret_token = "YOUR_RANDOM_SECRET_TOKEN"

# RunPod Callback Token (optional)
# If left empty, telegram_secret_token will be used
runpod_callback_token = "YOUR_RUNPOD_CALLBACK_TOKEN"

# Hugging Face Token (for Pyannote model)
# Get at https://huggingface.co/settings/tokens
hf_token = "YOUR_HF_TOKEN"

# RunPod API Key
# Get at https://www.runpod.io/console/user/settings
runpod_api_key = "YOUR_RUNPOD_API_KEY"

# RunPod Endpoint URL (created after deploying the RunPod service)
# Format: https://api.runpod.ai/v2/{endpoint_id}
runpod_endpoint_url = "https://api.runpod.ai/v2/YOUR_ENDPOINT_ID"

# === OPTIONAL PARAMETERS ===

# AWS Region
aws_region = "us-east-1"

# Environment (dev, staging, prod)
environment = "prod"

# S3 Bucket Name (must be globally unique)
s3_bucket_name = "callsum-prod-your-unique-suffix"

# Alert email (leave empty if email notifications are not needed)
alert_email = "your@email.com"

# Budget limits (USD)
monthly_budget_limit = 25  # Total monthly limit
runpod_monthly_limit = 15  # RunPod limit

# Enable detailed cost tracking
enable_cost_tracking = true

# Lambda configuration
lambda_timeout = 60      # seconds
lambda_memory  = 512     # MB

# DynamoDB table for jobs
dynamodb_table_name = "callsum-jobs"

# === DIGITALOCEAN SPACES (OPTIONAL) ===
# Use if you want to store files in DigitalOcean Spaces instead of AWS S3
# Cost: ~$5/month for 250 GB (cheaper than AWS S3)

# Enable DigitalOcean Spaces instead of AWS S3
use_digitalocean_spaces = false  # Set to true to use DO Spaces

# DigitalOcean Spaces Endpoint
# Format: https://<region>.digitaloceanspaces.com
# Regions: nyc3, sfo3, sgp1, fra1, ams3
s3_endpoint = "https://fra1.digitaloceanspaces.com"

# DigitalOcean Spaces Keys
# Get from: DigitalOcean -> API -> Spaces Keys
s3_access_key = "YOUR_DO_SPACES_ACCESS_KEY"
s3_secret_key = "YOUR_DO_SPACES_SECRET_KEY"

# IMPORTANT: When using DO Spaces, create the Space manually with the name from s3_bucket_name
# For example: callsum-prod-your-unique-suffix

# === DIGITALOCEAN SPACES SETUP INSTRUCTIONS ===
# 1. Create an account at digitalocean.com
# 2. Navigate to: Manage -> Spaces -> Create Space
# 3. Choose a region (e.g.: Frankfurt - fra1)
# 4. Space name: same as s3_bucket_name above
# 5. Navigate to: API -> Spaces Keys -> Generate New Key
# 6. Copy Access Key and Secret Key into the variables above
# 7. Set use_digitalocean_spaces = true
# 8. Run terraform apply
]]>
